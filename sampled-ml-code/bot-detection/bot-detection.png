      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Minimize the impact of bot activity on legitimate users subject to guardrails.\n\n- spam impression rates\n- reject friend requests marked as spam\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
