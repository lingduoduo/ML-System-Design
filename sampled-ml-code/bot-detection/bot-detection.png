      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3A",
      "roundness": null,
      "seed": 511496053,
      "version": 46,
      "versionNonce": 766831184,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773937380912,
      "link": null,
      "locked": false,
      "text": "Whenever a new post is created we'll run it through our lightweight model",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Whenever a new post is created we'll run it through our lightweight model",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "6hDhgxGyQHC5qRFjG5aNV",
      "type": "text",
      "x": 1232.145581412049,
      "y": -1096.7595318681374,
      "width": 1980.3587646484375,
      "height": 125,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3B",
      "roundness": null,
      "seed": 965265659,
      "version": 145,
      "versionNonce": 1866058928,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773937384231,
      "link": null,
      "locked": false,
      "text": "Re-trigger the model when important events happen: user reports, \na significant number of views, \ndisappointed comments, etc. \n\nTwo-staged approach with caching is well-suited for this because we can quickly re-classify content that has been updated and we don't need to recompute the parts of the model that haven't changed",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Re-trigger the model when important events happen: user reports, \na significant number of views, \ndisappointed comments, etc. \n\nTwo-staged approach with caching is well-suited for this because we can quickly re-classify content that has been updated and we don't need to recompute the parts of the model that haven't changed",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "c8Pvn7EypkYhja-bIBBke",
