      "updated": 1773937386654,
      "link": null,
      "locked": false,
      "text": "Positive Suppression: If few positive examples are available with behavioral data our model will learn a false conclusion: that any behavioral indicators are a sign that the content is benign.\nCalibration: calibration layer is robust to the fact that we're re-triggering the model on the same content multiple times.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Positive Suppression: If few positive examples are available with behavioral data our model will learn a false conclusion: that any behavioral indicators are a sign that the content is benign.\nCalibration: calibration layer is robust to the fact that we're re-triggering the model on the same content multiple times.",
      "autoResize": true,
      "lineHeight": 1.25
    },
