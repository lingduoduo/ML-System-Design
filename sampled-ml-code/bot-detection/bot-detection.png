    {
      "id": "pkvxzJPpD94nLUcGDcAfm",
      "type": "text",
      "x": 583.7315189120491,
      "y": -33.9900006181374,
      "width": 786.2393798828125,
      "height": 525,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
