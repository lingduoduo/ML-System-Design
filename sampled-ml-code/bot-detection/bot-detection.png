    {
      "id": "8Bs8Enb5pjgJwVEKw27Tf",
      "type": "text",
      "x": 18.61433141204907,
      "y": -2598.2478131181374,
      "width": 663.5196533203125,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b3L",
      "roundness": null,
      "seed": 921252528,
      "version": 15,
      "versionNonce": 782243408,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1773961941818,
      "link": null,
      "locked": false,
      "text": "What is the scale of the problem? \nWhat is the base prevalence of bot posts on the platform?\nWhat happens if we wrongly classify a real user as a bot? \nHow quickly do we need to detect bot activity?\nDo we have a golden truth of whether an account is a bot or not? \n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "What is the scale of the problem? \nWhat is the base prevalence of bot posts on the platform?\nWhat happens if we wrongly classify a real user as a bot? \nHow quickly do we need to detect bot activity?\nDo we have a golden truth of whether an account is a bot or not? \n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
