      "isDeleted": true,
      "boundElements": [],
      "updated": 1773937370816,
      "link": null,
      "locked": false,
      "text": "A binary classification: is this post harmful or not?\n\nWhen posts are created, we'll classify them as harmful or not\nOur classifier will calibrate to guarantees that we meet the guardrail precision\nFeed the output to the systems to take actions, either delete the posts, or flag it for review.\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "A binary classification: is this post harmful or not?\n\nWhen posts are created, we'll classify them as harmful or not\nOur classifier will calibrate to guarantees that we meet the guardrail precision\nFeed the output to the systems to take actions, either delete the posts, or flag it for review.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
