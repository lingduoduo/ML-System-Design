      "versionNonce": 1588069456,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1773937404398,
      "link": null,
      "locked": false,
      "text": "True multi-modal learning with attention between all modalities\nAbility to handle missing modalities naturally\nEfficient handling of behavioral features through attention mechanisms",
