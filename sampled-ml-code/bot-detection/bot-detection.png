      "boundElements": [],
      "updated": 1773937401585,
      "link": null,
      "locked": false,
      "text": "It can't capture interactions between modalities \nIt makes it harder to incorporate behavioral and user features, especially as interactions with text or images\nIt requires running two separate models for every piece of content",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "It can't capture interactions between modalities \nIt makes it harder to incorporate behavioral and user features, especially as interactions with text or images\nIt requires running two separate models for every piece of content",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "Wr86-U2MeDYByXU6DSct5",
      "type": "text",
